# MySQL Configuration
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=ebookstore_db
MYSQL_USER=admin
MYSQL_PASSWORD=admin_pass
MYSQL_PORT=3306

# Read-only user for reports
DB_USER_READ=relatorio_user
DB_PASS_READ=relatorio_pass

# Application Config
NODE_ENV=development
API_PORT=3000
RELATORIOS_PORT=3001

# Keycloak (autenticação)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=ebookstore
KEYCLOAK_CLIENT_ID=ebookstore-app
KEYCLOAK_AUDIENCE=ebookstore-api
# Issuer: como os clientes (Postman/navegador) acessam o Keycloak — valida o claim 'iss' do token
KEYCLOAK_ISSUER=http://localhost:8080/realms/ebookstore
# JWKS: como as APIs acessam o Keycloak DENTRO da rede Docker — busca das chaves públicas
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/ebookstore/protocol/openid-connect/certs
