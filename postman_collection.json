                  "pm.collectionVariables.set('randomCpf', cpf);",
                  "pm.collectionVariables.set('randomEmail', `vendedor.${Date.now()}@email.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('vendedorId', pm.response.json().id);",
                  "}",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Carlos Pereira\",\n  \"email\": \"{{randomEmail}}\",\n  \"cpf\": \"{{randomCpf}}\",\n  \"telefone\": \"11999990000\",\n  \"comissaoPercentual\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/vendedores",
              "host": ["{{base_url}}"],
              "path": ["vendedores"]
            }
          }
        },
        {
          "name": "Listar vendedores",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/vendedores",
              "host": ["{{base_url}}"],
              "path": ["vendedores"]
            }
          }
        },
        {
          "name": "Buscar vendedor por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/vendedores/{{vendedorId}}",
              "host": ["{{base_url}}"],
              "path": ["vendedores", "{{vendedorId}}"]
            }
          }
        },
        {
          "name": "Atualizar vendedor",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let cpf = '';",
                  "for (let i = 0; i < 11; i++) cpf += Math.floor(Math.random() * 10);",
                  "pm.collectionVariables.set('randomCpf', cpf);",
                  "pm.collectionVariables.set('randomEmail', `vendedor.upd.${Date.now()}@email.com`);"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Carlos Pereira\",\n  \"email\": \"{{randomEmail}}\",\n  \"cpf\": \"{{randomCpf}}\",\n  \"telefone\": \"11999990000\",\n  \"comissaoPercentual\": 7.5\n}"
            },
            "url": {
              "raw": "{{base_url}}/vendedores/{{vendedorId}}",
              "host": ["{{base_url}}"],
              "path": ["vendedores", "{{vendedorId}}"]
            }
          }
        },
        {
          "name": "Remover vendedor",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function randomDigits(n) { let s = ''; for (let i = 0; i < n; i++) s += Math.floor(Math.random() * 10); return s; }",
                  "const baseUrl = pm.collectionVariables.get('base_url');",
                  "pm.sendRequest({",
                  "  url: `${baseUrl}/vendedores`,",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({",
                  "    nome: 'Vendedor descartável',",
                  "    email: `vendedor.delete.${Date.now()}@email.com`,",
                  "    cpf: randomDigits(11),",
                  "    telefone: '11999990000'",
                  "  }) }",
                  "}, (err, res) => {",
                  "  if (!err && res.code === 201) pm.collectionVariables.set('vendedorIdToDelete', res.json().id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/vendedores/{{vendedorIdToDelete}}",
              "host": ["{{base_url}}"],
              "path": ["vendedores", "{{vendedorIdToDelete}}"]
            },
            "description": "Cria um vendedor descartável no pré-script e o remove em seguida — assim a remoção não afeta o {{vendedorId}} usado pela pasta 'Vendas'."
          }
        }
      ]
    },
    {
      "name": "Catálogo",
      "item": [
        {
          "name": "Listar catálogo",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/catalogo",
              "host": ["{{base_url}}"],
              "path": ["catalogo"]
            }
          }
        },
        {
          "name": "Cadastrar produto",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('produtoId', pm.response.json().id);",
                  "}",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Dom Casmurro\",\n  \"autor\": \"Machado de Assis\",\n  \"genero\": \"Romance\",\n  \"descricao\": \"Clássico da literatura brasileira\",\n  \"preco\": 39.9\n}"
            },
            "url": {
              "raw": "{{base_url}}/catalogo",
              "host": ["{{base_url}}"],
              "path": ["catalogo"]
            }
          }
        },
        {
          "name": "Atualizar produto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Dom Casmurro\",\n  \"autor\": \"Machado de Assis\",\n  \"genero\": \"Romance\",\n  \"descricao\": \"Clássico da literatura brasileira - edição revisada\",\n  \"preco\": 44.9\n}"
            },
            "url": {
              "raw": "{{base_url}}/catalogo/{{produtoId}}",
              "host": ["{{base_url}}"],
              "path": ["catalogo", "{{produtoId}}"]
            }
          }
        },
        {
          "name": "Excluir produto (definitivo, bloqueado se houver venda)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/catalogo/{{produtoId}}",
              "host": ["{{base_url}}"],
              "path": ["catalogo", "{{produtoId}}"]
            }
          }
        },
        {
          "name": "Tirar do catálogo (sem excluir)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/catalogo/{{produtoId}}/remover-catalogo",
              "host": ["{{base_url}}"],
              "path": ["catalogo", "{{produtoId}}", "remover-catalogo"]
            }
          }
        },
        {
          "name": "Reincluir no catálogo",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/catalogo/{{produtoId}}/reativar",
              "host": ["{{base_url}}"],
              "path": ["catalogo", "{{produtoId}}", "reativar"]
            }
          }
        }
      ]
    },
    {
      "name": "Vendas",
      "item": [
        {
          "name": "Criar venda",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('vendaId', pm.response.json().id);",
                  "}",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": {{clienteId}},\n  \"vendedorId\": {{vendedorId}},\n  \"itens\": [\n    {\n      \"produtoId\": {{produtoId}},\n      \"quantidade\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/vendas",
              "host": ["{{base_url}}"],
              "path": ["vendas"]
            }
          }
        },
        {
          "name": "Listar vendas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/vendas",
              "host": ["{{base_url}}"],
              "path": ["vendas"]
            }
          }
        },
        {
          "name": "Confirmar venda",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/vendas/{{vendaId}}/confirmar",
              "host": ["{{base_url}}"],
              "path": ["vendas", "{{vendaId}}", "confirmar"]
            },
            "description": "Gera as cópias únicas (chaves/números de série) de cada ebook comprado e, após a confirmação, dispara o envio SIMULADO das chaves por e-mail ao cliente. Não há SMTP real: o 'e-mail' é registrado nos logs do container api-principal (procure por 'E-MAIL (SIMULADO)')."
          }
        },
        {
          "name": "Cancelar venda",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/vendas/{{vendaId}}/cancelar",
              "host": ["{{base_url}}"],
              "path": ["vendas", "{{vendaId}}", "cancelar"]
            }
          }
        }
      ]
    },
    {
      "name": "Relatórios",
      "item": [
        {
