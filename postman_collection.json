              "path": ["api", "relatorios", "mais-vendidos"]
            }
          }
        },
        {
          "name": "Relatório por cliente",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/relatorios/cliente/{{clienteId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "relatorios", "cliente", "{{clienteId}}"]
            }
          }
        },
        {
          "name": "Consumo médio",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/relatorios/consumo-medio",
              "host": ["{{base_url}}"],
              "path": ["api", "relatorios", "consumo-medio"]
            }
          }
        }
      ]
    }
  ]
}
